# ─── DATABASE ────────────────────────────────────────────────────────────────
# For LOCAL development (SQLite):
DATABASE_URL="file:./dev.db"

# For PRODUCTION on Vercel (Turso):
# DATABASE_URL="libsql://your-db-name.turso.io"
# TURSO_AUTH_TOKEN="your-turso-auth-token"

# ─── NEXTAUTH ─────────────────────────────────────────────────────────────────
# In production, change to your actual Vercel URL:
# NEXTAUTH_URL="https://your-project-name.vercel.app"
NEXTAUTH_URL="http://localhost:3000"

# Generate a strong secret: https://generate-secret.vercel.app/32
NEXTAUTH_SECRET="replace-this-with-a-random-32+-character-secret"

# ─── ADMIN CREDENTIALS ────────────────────────────────────────────────────────
# These create the admin account on first seed
ADMIN_EMAIL="admin@gamepulse.com"
ADMIN_PASSWORD="YourStrongPasswordHere"

# ─── IMAGE HOSTING (Optional) ─────────────────────────────────────────────────
# For production image uploads, sign up at https://cloudinary.com (free tier)
# CLOUDINARY_CLOUD_NAME=""
# CLOUDINARY_API_KEY=""
# CLOUDINARY_API_SECRET=""
